{
  "name": "wvlet-ui",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "ui": "pnpm --filter wvlet-ui-main run dev",
    "build-ui": "pnpm --filter wvlet-ui-main run build",
    "playground": "pnpm --filter wvlet-ui-playground run dev",
    "build-playground": "pnpm --filter wvlet-ui-playground run build",
    "build-vscode-extension": "pnpm --filter wvlet run package"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.32.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.0",
    "apache-arrow": "^21.1.0",
    "koffi": "^3.1.1",
    "monaco-editor": "^0.55.1",
    "rollup": "^4.62.2"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "esbuild": "^0.28.1",
    "jsdom": "29.1.1",
    "postcss": "^8.5.22",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-monaco-editor": "^1.1.0"
  },
  "optionalDependencies": {
