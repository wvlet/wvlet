{
  "name": "wvlet-ui",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "ui": "pnpm --filter wvlet-ui-main run dev",
    "build-ui": "pnpm --filter wvlet-ui-main run build",
    "playground": "pnpm --filter wvlet-ui-playground run dev",
    "build-playground": "pnpm --filter wvlet-ui-playground run build",
    "build-vscode-extension": "pnpm --filter wvlet run package"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.32.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.0",
    "apache-arrow": "^21.1.0",
    "koffi": "^2.16.0",
    "monaco-editor": "^0.55.1",
    "rollup": "^4.61.1"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.28.1",
    "jsdom": "29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-monaco-editor": "^1.1.0"
  },
  "optionalDependencies": {
    "lightningcss-linux-x64-gnu": "^1.32.0"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "^3.4.0",
      "serialize-javascript": "^7.0.5",
      "uuid": "^14.0.0",
      "webpackbar": "^7.0.0",
      "diff": "^9.0.0",
      "mermaid": "^11.15.0",
      "@babel/plugin-transform-modules-systemjs": "^7.29.4",
      "fast-uri": "^3.1.2"
    },
    "onlyBuiltDependencies": [
