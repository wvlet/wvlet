{
  "name": "wvlet",
  "displayName": "Wvlet",
  "description": "Wvlet query language support for Visual Studio Code",
  "version": "2025.3.0",
  "engines": {
    "vscode": "^1.104.0"
  },
  "main": "./out/extension.js",
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "wvlet",
    "query",
    "sql",
    "data"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wvlet/wvlet"
  },
  "bugs": {
    "url": "https://github.com/wvlet/wvlet/issues"
  },
  "homepage": "https://wvlet.org",
  "publisher": "wvlet",
  "icon": "icon.png",
  "contributes": {
    "languages": [
      {
        "id": "wvlet",
        "aliases": [
          "Wvlet",
          "wvlet",
          "wv"
        ],
        "extensions": [
          ".wv"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wvlet",
        "scopeName": "source.wvlet",
        "path": "./syntaxes/wvlet.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/vscode": "^1.104.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.0"
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npm run compile && vsce package"
  },
  "author": "Wvlet Team",
  "license": "Apache-2.0"
}
