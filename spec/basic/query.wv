-- Define a table from json file
model person_q = {
  from 'person.json'
}

-- limit
from person_q
limit 5

-- sorting
from person_q
order by id

--- ascending order
from person_q
order by id asc

-- sort & limit
from person_q
order by id desc
limit 2


-- limit & sort
from person_q
limit 2
order by id asc

-- projection
from person_q
select
  id,
  name

-- rename column
from person_q
select
  person_id = id,
  person_name = name
